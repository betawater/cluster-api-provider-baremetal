  "addons": [
    {
      "name": "calico",
      "type": "helm",
      "version": "v3.28.1",
      "contentPath": "charts/calico-v3.28.1.tgz",
      "namespace": "kube-system",
      "dependencies": [],
      "variables": [
        {
          "name": "podCIDR",
          "type": "string",
          "description": "Pod network CIDR",
          "required": true
        },
        {
          "name": "ipam",
          "type": "string",
          "description": "IPAM mode",
          "required": false,
          "default": "calico-ipam",
          "enum": ["calico-ipam", "host-local"]
        }
      ],
      "defaultValues": {
        "ipam": "calico-ipam",
        "typhaReplicas": 1
      },
